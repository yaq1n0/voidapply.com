{
  "name": "voidapply",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "npm run build && wrangler dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "screenshot": "playwright test playwright/screenshot.spec.ts --project=chromium",
    "screenshot:dark": "playwright test playwright/screenshot.spec.ts --project=chromium-dark",
    "screenshot:all": "playwright test playwright/screenshot.spec.ts",
    "test:e2e": "playwright test --grep-invert \"screenshot (skin|rejection):\"",
    "test:e2e:smoke": "playwright test playwright/smoke.spec.ts",
    "test:e2e:skins": "playwright test playwright/skins",
    "test:e2e:rejections": "playwright test playwright/rejections",
    "test:e2e:core": "playwright test playwright/core",
    "e2e:install": "npx playwright install --with-deps chromium",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.2.0",
    "framer-motion": "^12.36.0",
    "fuse.js": "^7.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.27.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vitest": "^3.2.4",
    "wrangler": "^4.72.0"
  }
}
